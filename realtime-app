pipeline {
    agent none

    stages {

        stage('backend') {
            agent {
                docker { image 'maven:3.9.9-eclipse-temurin-11' }
            }
            steps {
                sh 'mvn --version'
            }
        }

        stage('frontend') {
            agent {
                docker { image 'node:16-alpine' }
            }
            steps {
                sh 'node --version'
            }
        }

    }
}
